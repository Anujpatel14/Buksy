# Optional: enable MySQL + login. If unset, Buksy uses local JSON file storage (no login).
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=buksy

# Public URL of this app (required for OAuth redirects). No trailing slash.
# Example: https://your-domain.com  or  http://127.0.0.1:3000
# BUKSY_PUBLIC_URL=http://127.0.0.1:3000

# GitHub OAuth App (optional; alternative to pasting a PAT in the UI)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# Optional extra scopes (default: read:user repo)
# GITHUB_OAUTH_SCOPE=read:user repo

# Notion public OAuth (optional; alternative to internal integration token)
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=

# Google Calendar OAuth (optional; enables free/busy capacity hints)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional
# PORT=3000
# NODE_ENV=development
